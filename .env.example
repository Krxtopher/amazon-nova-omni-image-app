# AWS Configuration for Amazon Bedrock
# Copy this file to .env and fill in your AWS credentials

# AWS Region where Bedrock is available
VITE_AWS_REGION=us-east-1

# AWS Credentials
# Note: For production, use AWS Cognito Identity Pool or AWS Amplify instead
VITE_AWS_ACCESS_KEY_ID=your_access_key_here
VITE_AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Alternative: Use AWS Cognito Identity Pool (recommended for production)
# Uncomment and configure in src/App.tsx
# VITE_AWS_COGNITO_IDENTITY_POOL_ID=your_identity_pool_id

# Prompt Enhancement Configuration
# Set to 'false' to use non-streaming Converse API, 'true' or omit for streaming ConverseStream API
VITE_USE_STREAMING_ENHANCEMENT=true
